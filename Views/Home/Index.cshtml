@model IEnumerable<ADO.Models.Employee>

@{
    ViewData["Title"] = "Employees";
    var deptList = ViewBag.Department as List<ADO.Models.Department>;
    var desgList = ViewBag.Desgination as List<ADO.Models.Desgination>;
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between">
            <h4 class="mb-0">Employee List</h4>
            <a asp-action="Create" class="btn btn-light btn-sm">
                + Create Employee
            </a>
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Emp ID</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>DOJ</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.ProfileImg != null)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.ProfileImg)"
                                         class="rounded-circle border"
                                         style="width:60px; height:60px; object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center"
                                         style="width:60px; height:60px;">
                                        N/A
                                    </div>
                                }
                            </td>

                            <td>@item.EmpId</td>
                            <td>@item.Name</td>
                            <td>
                                @deptList.FirstOrDefault(d => d.DeptID == item.DeptID).DeptName
                            </td>

                            <td>
                                @desgList.FirstOrDefault(d => d.DesgID == item.DesgID).DesgName
                            </td>

                            <td>@item.DOJ.ToString("dd MMM yyyy")</td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.EmpId"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.EmpId"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.EmpId"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
